# GitCAD Agent AI configuration
#
# Copy to .env for local development:
# cp .env.example .env

# Preferred provider for the live agent path.
# The deterministic generator works without API keys.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:5566
OPENROUTER_SITE_NAME=GitCAD Agent

# Native provider fallbacks/options.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model selectors used by the agent wrapper or Gitclaw-compatible runtime.
GITCAD_MODEL_PROVIDER=google
GITCAD_MODEL=gemini-2.0-flash
GITCAD_FALLBACK_MODEL=claude-sonnet-4-5-20251001

# Optional OpenRouter adapter model if your GitAgent runtime supports OpenRouter.
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_FALLBACK_MODEL=~openai/gpt-latest

# Runtime behavior
GITCAD_MAX_REPAIR_ATTEMPTS=2
GITCAD_GENERATED_DIR=src/generated
GITCAD_DEFAULT_PROMPT="Create a 12m x 8m apartment floorplan with a living room, bedroom, kitchen, bathroom, one main door, and two windows."

# Set to 1 if the live LLM adapter should fail instead of falling back.
GITCAD_LLM_REQUIRED=0
